# Production Environment Configuration for Snap-It Backend
# Copy this file to .env.production and fill in the values

# ============================================================================
# Database Configuration
# ============================================================================

# Full PostgreSQL connection URL
DATABASE_URL="postgresql://snapit:CHANGE_ME_SECURE_PASSWORD@db:5432/snapit"

# Individual database connection parameters (used by docker-compose.prod.yml)
DB_HOST=db
DB_PORT=5432
DB_USER=snapit
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_NAME=snapit

# ============================================================================
# Application Configuration
# ============================================================================

# Port the backend server will listen on
PORT=9000

# Node environment (should be "production" for VPS deployment)
NODE_ENV=production

# ============================================================================
# Security Configuration
# ============================================================================

# Admin panel password (used for analytics dashboard authentication)
# IMPORTANT: Change this to a strong, unique password!
ADMIN_PASSWORD="CHANGE_ME_TO_STRONG_PASSWORD"

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed origins for CORS
# Include your production web app and admin panel URLs
ALLOWED_ORIGINS="https://snapit.yourdomain.com,https://admin.snapit.yourdomain.com"

# Example for multiple environments:
# ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com,https://staging.example.com"

# ============================================================================
# Optional: Additional Configuration
# ============================================================================

# Uncomment and configure if needed:
# LOG_LEVEL=info
# MAX_REQUEST_SIZE=10mb
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
