# Backend Environment Variables
DATABASE_URL="postgresql://snapit:snapit@localhost:5432/snapit"

# Local development port — must match NEXT_PUBLIC_BACKEND_URL in apps/admin/.env.local
# Docker production uses port 9000 (hardcoded in docker-compose.prod.yml)
PORT=3001

ADMIN_PASSWORD="change-me-in-production"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"
NODE_ENV="development"
