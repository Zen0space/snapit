// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id        String   @id @default(cuid())
  type      String
  tool      String?
  meta      String?
  visitorId String?
  country   String?
  region    String?
  browser   String?
  os        String?
  device    String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([country])
  @@index([visitorId])
}

/// Stores the anonymous visitor's consent choice.
/// One record per visitorId — upserted whenever the user changes their preference.
/// Future: when a user creates an account they can claim this visitorId.
model CookieConsent {
  id        String   @id @default(cuid())
  visitorId String   @unique
  consent   String   // "all" | "necessary"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
